# ── VR Spark cluster configuration ──────────────────────────────────────────
# Copy to config/cluster.env and edit. Sourced by day0 scripts, lane scripts,
# swap-lane.sh, and the gateway compose file.

# LAN identities (10GbE RJ45 side — normal network / Tailscale)
SPARK_A_HOST=spark-a                # hostname or Tailscale MagicDNS name
SPARK_B_HOST=spark-b
SPARK_A_LAN_IP=192.168.1.50         # edit to your LAN
SPARK_B_LAN_IP=192.168.1.51

# SSH from Spark A (head) to Spark B (worker). Per-node usernames may differ —
# if so, add a Host entry in ~/.ssh/config on A mapping B's IP to its user.
SPARK_B_SSH=vr@spark-b

# Fabric (QSFP ConnectX-7 direct link — cluster lane only)
FABRIC_IFACE=enp1s0f0np0            # verify with `ip -br link` on your units
SPARK_A_FABRIC_IP=192.168.100.1
SPARK_B_FABRIC_IP=192.168.100.2
FABRIC_CIDR=24
# NCCL_IB_GID_INDEX is discovered by day0/03-nccl-validate.sh (commonly 3,
# but has differed per node in the wild — trust the script, not the default).

# Model cache. 4TB NVMe per node; keep the HF cache OFF the OS partition
# if you add storage later. Weights are staged once on A, rsynced to B
# over the fabric (see ops/RUNBOOK.md → "Weight staging").
HF_CACHE=/home/vr/.cache/huggingface
HF_TOKEN=hf_xxx                     # needed for gated repos

# Serving ports
BRAIN_PORT=8000                     # Spark A, gpt-oss-120b
CODER_PORT=8001                     # Spark B, Qwen3.6-27B
FLEET_PORT=8888                     # cluster lane (head node)
GATEWAY_PORT=4000                   # LiteLLM

# vLLM images. Pin deliberately; upgrade deliberately. Both are aarch64/sm_121
# aware. The eugr image is community-tested nightly on Spark specifically.
VLLM_IMAGE_NV=nvcr.io/nvidia/vllm:26.06-py3
VLLM_IMAGE_COMMUNITY=eugr/spark-vllm:latest

# GPU memory utilization defaults. These are STARTING points — bracket in
# 0.005 steps per the knife-edge procedure in ops/RUNBOOK.md before trusting.
BRAIN_GMU=0.85
CODER_GMU=0.85

# Frontier fallback (optional but recommended). Leave empty to disable the
# `frontier` route in the gateway.
ANTHROPIC_API_KEY=
